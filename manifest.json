{
    "manifest_version": 3,
    "name": "PassGuard - Breach Checker",
    "version": "1.0",
    "description": "Professional-grade password breach and complexity auditor.",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.png"
    },
    "host_permissions": [
        "https://api.pwnedpasswords.com/*"
    ]
}